# Upstash Redis (Vercel Marketplace or https://upstash.com — REST API)
# Required for share-link storage and rate limits once `/api/share` is wired.
UPSTASH_REDIS_REST_URL=test
UPSTASH_REDIS_REST_TOKEN=test

# Anthropic API key — required for all /api/ai features
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

